{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ClTechCoreDB;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=True;"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-change-in-production-at-least-32-characters-long",
    "Issuer": "cltech-api",
    "Audience": "cltech-app",
    "ExpiresInMinutes": 60,
    "RefreshTokenExpiresInDays": 7
  },
  "Redis": {
    "ContainerName": "localhost:6379",
    "Enabled": true,
    "CacheDurationMinutes": 30
  },
  "OpenAI": {
    "ApiKey": "sk-your-openai-api-key-here",
    "Model": "gpt-4"
  },
  "Stripe": {
    "SecretKey": "sk_test_your-stripe-key",
    "PublicKey": "pk_test_your-stripe-key"
  },
  "Email": {
    "From": "noreply@cltech.com",
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "your-app-password"
  },
  "WhatsApp": {
    "BaileySessionPath": "/app/sessions",
    "WebhookUrl": "https://yourdomain.com/api/v1/webhooks/whatsapp",
    "TimeoutSeconds": 30
  },
  "RateLimiting": {
    "Enabled": true,
    "RateLimitPerMinute": 100,
    "RateLimitPerHour": 1000
  },
  "Features": {
    "EnableAI": true,
    "EnableMultiTenant": true,
    "EnableBilling": true,
    "EnableWhatsAppBot": true
  }
}
