# ==========================================
# CL TECH CORE - BACKEND ENVIRONMENT CONFIG
# ==========================================

# Servidor
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=sua_chave_secreta_muito_longa_e_aleatoria_mude_isso_em_producao
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# Database
DB_PATH=./data/cltech.db

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,electron://

# Compiladores (caminho ou comando)
CPP_COMPILER=g++
JAVA_COMPILER=javac

# Caminhos
UPLOAD_DIR=./uploads
REPO_PATH=./repos

# Logging
LOG_LEVEL=debug

# Git (Opcional)
GIT_REPO_URL=https://github.com/seu-usuario/cl-tech-core-data.git
