# ============================================================================
# ENVIRONMENT - PRODUCTION
# ============================================================================

# ASPNETCORE
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# DATABASE
Database__ConnectionString=Server=sqlserver,1433;Database=ClTechCoreDB;User Id=sa;Password=YourStrongPassword123!;

# JWT
JWT__SecretKey=your-super-secret-key-change-in-production-at-least-32-characters-long
JWT__Issuer=cltech-api
JWT__Audience=cltech-app
JWT__ExpiresInMinutes=60
JWT__RefreshTokenExpiresInDays=7

# REDIS
REDIS__ContainerName=redis:6379
REDIS__Enabled=true
REDIS__CacheDurationMinutes=30

# EXTERNAL SERVICES
OPENAI__ApiKey=sk-your-openai-api-key-here
OPENAI__Model=gpt-4
OPENAI__MaxTokens=150

STRIPE__SecretKey=sk_live_your-stripe-key
STRIPE__PublicKey=pk_live_your-stripe-key

MERCADOPAGO__AccessToken=your-mercado-pago-token

# EMAIL
EMAIL__From=noreply@cltech.com
EMAIL__SmtpServer=smtp.gmail.com
EMAIL__SmtpPort=587
EMAIL__SmtpUsername=your-email@gmail.com
EMAIL__SmtpPassword=your-app-password

# WHATSAPP BOT
WHATSAPP__BaileySessionPath=/app/sessions
WHATSAPP__WebhookUrl=https://yourdomain.com/api/v1/webhooks/whatsapp
WHATSAPP__TimeoutSeconds=30

# RATE LIMITING
RATELIMITING__Enabled=true
RATELIMITING__RateLimitPerMinute=100
RATELIMITING__RateLimitPerHour=1000

# FEATURES
FEATURES__EnableAI=true
FEATURES__EnableMultiTenant=true
FEATURES__EnableBilling=true
FEATURES__EnableWhatsAppBot=true

# LOGGING
LOGGING__Level=Information
LOGGING__LogPath=/app/logs

# STORAGE (S3/Azure Blob)
STORAGE__Provider=AzureBlob
STORAGE__ConnectionString=your-azure-storage-connection-string
